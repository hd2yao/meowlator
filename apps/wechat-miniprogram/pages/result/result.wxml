<view class="page" wx:if="{{result}}">
  <view class="card">
    <view class="section-title">猫猫台词</view>
    <view class="cat-line">{{copy.catLine}}</view>
  </view>

  <view class="card">
    <view class="section-title">依据解释</view>
    <view>{{copy.evidence}}</view>
  </view>

  <view class="card risk-card" wx:if="{{result.risk}}">
    <view class="section-title">疑似不适风险</view>
    <view>风险等级：{{riskLevelText}}（{{riskScoreText}}）</view>
    <view wx:if="{{riskEvidenceText}}">风险依据：{{riskEvidenceText}}</view>
    <view class="risk-disclaimer">{{riskDisclaimerText}}</view>
  </view>

  <view class="card">
    <view class="section-title">意图 Top3</view>
    <view wx:for="{{intentTop3Display}}" wx:key="label">
      {{item.label}} - {{item.probPercent}}%
    </view>
  </view>

  <view class="feedback-row">
    <button bindtap="onCorrect">准</button>
    <button bindtap="onWrong">不准</button>
  </view>

  <picker mode="selector" range="{{intentOptions}}" bindchange="onPickTrueLabel" wx:if="{{showLabelPicker}}">
    <view class="picker">选择真实意图：{{pickedLabelText}}</view>
  </picker>

  <button class="button-primary" bindtap="onShareTap">生成分享</button>
</view>
