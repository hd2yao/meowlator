.result-page {
  min-height: 100vh;
  background: #f3f4f6;
  position: relative;
}

.hero-area {
  position: relative;
  height: 45vh;
  min-height: 620rpx;
  background: #d1d5db;
  overflow: hidden;
}

.hero-image {
  width: 100%;
  height: 100%;
}

.hero-fallback {
  width: 100%;
  height: 100%;
  display: flex;
  align-items: center;
  justify-content: center;
  color: rgba(255, 255, 255, 0.9);
  font-size: 52rpx;
  font-weight: 600;
  background: linear-gradient(180deg, #9ca3af 0%, #d1d5db 100%);
}

.status-row {
  position: absolute;
  top: 10rpx;
  left: 22rpx;
  right: 22rpx;
  display: flex;
  align-items: center;
  justify-content: space-between;
  z-index: 3;
}

.status-row-light {
  color: #fff;
}

.status-time {
  font-size: 28rpx;
  font-weight: 700;
}

.status-island {
  width: 240rpx;
  height: 60rpx;
  border-radius: 30rpx;
  background: #000;
}

.status-battery {
  width: 38rpx;
  height: 22rpx;
  border-radius: 8rpx;
  border: 2rpx solid rgba(255, 255, 255, 0.9);
}

.back-btn {
  position: absolute;
  left: 24rpx;
  top: 102rpx;
  width: 64rpx;
  height: 64rpx;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  background: rgba(0, 0, 0, 0.35);
  color: #fff;
  font-size: 52rpx;
  line-height: 1;
  z-index: 4;
}

.source-row {
  position: absolute;
  left: 24rpx;
  bottom: 28rpx;
  display: flex;
  align-items: center;
  gap: 14rpx;
  z-index: 4;
}

.source-badge,
.source-time {
  height: 48rpx;
  border-radius: 24rpx;
  padding: 0 18rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  background: rgba(0, 0, 0, 0.5);
  color: #fff;
  font-size: 24rpx;
  font-weight: 600;
}

.source-badge {
  gap: 10rpx;
}

.source-dot {
  width: 12rpx;
  height: 12rpx;
  border-radius: 50%;
  background: #34d399;
}

.result-sheet {
  margin-top: -34rpx;
  border-top-left-radius: 42rpx;
  border-top-right-radius: 42rpx;
  background: #f3f4f6;
  padding: 26rpx 24rpx 34rpx;
  position: relative;
  z-index: 5;
}

.sheet-grabber {
  width: 96rpx;
  height: 10rpx;
  border-radius: 999rpx;
  background: #c4c9cf;
  margin: 0 auto 28rpx;
}

.summary-row {
  display: flex;
  justify-content: space-between;
  align-items: flex-start;
  gap: 20rpx;
}

.summary-main {
  display: flex;
  flex-direction: column;
  gap: 8rpx;
}

.intent-code {
  color: #ff8a4c;
  font-size: 30rpx;
  font-weight: 700;
  letter-spacing: 1.5rpx;
}

.intent-headline {
  color: #1f2937;
  font-size: 66rpx;
  line-height: 1.15;
  font-weight: 800;
}

.confidence-card {
  width: 120rpx;
  height: 130rpx;
  border-radius: 24rpx;
  background: rgba(255, 138, 76, 0.12);
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
}

.confidence-value {
  color: #ff8a4c;
  font-size: 48rpx;
  font-weight: 800;
}

.confidence-label {
  color: #ff8a4c;
  font-size: 20rpx;
  font-weight: 600;
}

.copy-card {
  margin-top: 28rpx;
  background: #fff;
  border-radius: 30rpx;
  padding: 26rpx;
  border: 2rpx solid #eceff4;
}

.copy-title {
  color: #1f2937;
  font-size: 32rpx;
  font-weight: 700;
  margin-bottom: 14rpx;
}

.copy-line {
  color: #4b5563;
  font-size: 36rpx;
  line-height: 1.5;
}

.copy-evidence {
  margin-top: 10rpx;
  color: #6b7280;
  font-size: 28rpx;
  line-height: 1.45;
}

.risk-card {
  margin-top: 18rpx;
  border-radius: 24rpx;
  background: #fff8e6;
  border: 2rpx solid #ffd27d;
  padding: 20rpx;
}

.risk-title {
  font-size: 28rpx;
  font-weight: 700;
  color: #9a5a00;
}

.risk-evidence {
  margin-top: 8rpx;
  color: #8d5524;
  font-size: 24rpx;
  line-height: 1.4;
}

.risk-disclaimer {
  margin-top: 8rpx;
  color: #8d5524;
  font-size: 22rpx;
}

.top3-card {
  margin-top: 20rpx;
  background: #fff;
  border-radius: 26rpx;
  padding: 18rpx 22rpx;
}

.top3-title {
  font-size: 28rpx;
  font-weight: 700;
  color: #1f2937;
  margin-bottom: 10rpx;
}

.top3-item {
  display: flex;
  align-items: center;
  justify-content: space-between;
  font-size: 26rpx;
  color: #4b5563;
  padding: 6rpx 0;
}

.feedback-title {
  margin-top: 28rpx;
  text-align: center;
  color: #9ca3af;
  font-size: 30rpx;
  font-weight: 700;
}

.feedback-row {
  margin-top: 20rpx;
  display: flex;
  gap: 16rpx;
}

.feedback-btn {
  flex: 1;
  height: 98rpx;
  border-radius: 999rpx;
  font-size: 42rpx;
  font-weight: 700;
  display: flex;
  align-items: center;
  justify-content: center;
}

.feedback-btn::after,
.share-btn::after,
.submit-btn::after {
  border: 0;
}

.feedback-ok {
  color: #10b981;
  background: #fff;
  border: 3rpx solid #10b981;
}

.feedback-bad {
  color: #ef4444;
  background: #fff;
  border: 3rpx solid #ef4444;
}

.share-btn {
  margin-top: 18rpx;
  height: 88rpx;
  border-radius: 999rpx;
  font-size: 30rpx;
  font-weight: 600;
  background: rgba(255, 138, 76, 0.1);
  color: #ff8a4c;
}

.sheet-mask {
  position: fixed;
  inset: 0;
  z-index: 30;
  background: rgba(17, 24, 39, 0.4);
  display: flex;
  align-items: flex-end;
}

.feedback-sheet {
  width: 100%;
  background: #fff;
  border-top-left-radius: 42rpx;
  border-top-right-radius: 42rpx;
  padding: 22rpx 24rpx 34rpx;
  box-sizing: border-box;
}

.sheet-header {
  margin-top: 8rpx;
  display: flex;
  align-items: center;
  justify-content: space-between;
}

.sheet-title {
  font-size: 44rpx;
  color: #1f2937;
  font-weight: 800;
}

.sheet-close {
  width: 56rpx;
  height: 56rpx;
  border-radius: 50%;
  background: #f3f4f6;
  display: flex;
  align-items: center;
  justify-content: center;
  color: #9ca3af;
  font-size: 34rpx;
}

.sheet-tip {
  margin-top: 8rpx;
  font-size: 28rpx;
  color: #6b7280;
}

.intent-grid {
  margin-top: 20rpx;
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 14rpx;
}

.intent-item {
  height: 88rpx;
  border-radius: 20rpx;
  background: #f3f4f6;
  color: #1f2937;
  font-size: 30rpx;
  font-weight: 600;
  display: flex;
  align-items: center;
  justify-content: center;
  text-align: center;
}

.intent-item-active {
  background: rgba(255, 138, 76, 0.14);
  color: #ff8a4c;
  border: 3rpx solid #ff8a4c;
}

.submit-btn {
  margin-top: 28rpx;
  height: 100rpx;
  border-radius: 999rpx;
  background: #ff8a4c;
  color: #fff;
  font-size: 38rpx;
  font-weight: 700;
}

.empty-page {
  min-height: 100vh;
  background: #f3f4f6;
  display: flex;
  align-items: center;
  justify-content: center;
  color: #6b7280;
  font-size: 30rpx;
}
