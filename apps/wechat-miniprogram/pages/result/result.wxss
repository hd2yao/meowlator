.page {
  padding: 24rpx;
  display: flex;
  flex-direction: column;
  gap: 20rpx;
}

.section-title {
  font-weight: 600;
  margin-bottom: 10rpx;
}

.cat-line {
  font-size: 34rpx;
  line-height: 1.4;
}

.feedback-row {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 12rpx;
}

.picker {
  background: #fff;
  border-radius: 12rpx;
  padding: 20rpx;
}

.risk-card {
  border: 1px solid #ffb703;
  background: #fff8e6;
}

.risk-disclaimer {
  margin-top: 10rpx;
  font-size: 24rpx;
  color: #8d5524;
}
